{
  "manifest_version": 3,
  "name": "YouTube Auto Jump",
  "version": "3.0.2",
  "description": "Automatically jump to a specific time on YouTube videos.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen"
    ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://youtu.be/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_icon": {
      "16": "images/icon/icon16.png",
      "48": "images/icon/icon48.png",
      "128": "images/icon/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "default_locale": "en",
  "icons": {
    "16": "images/icon/icon16.png",
    "48": "images/icon/icon48.png",
    "128": "images/icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://youtu.be/*"
      ],
      "resources": [
        "images/ui/*",
        "lib/*",
        "lib/songDetection/*",
        "lib/vendor/onnxruntime/*",
        "models/fireredvad/aed/*",
        "offscreen.html",
        "offscreen.js"
      ]
    }
  ]
}
